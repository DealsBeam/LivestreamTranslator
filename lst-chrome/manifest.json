{
  "manifest_version": 3,
  "name": "LiveStream Translator",
  "version": "1.0.0",
  "description": "Free real-time Japanese → English captions for TwitCasting and any livestream. Powered by Gemini AI.",

  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "tabs",
    "offscreen"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LiveStream Translator"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
